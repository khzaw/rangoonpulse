{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Asia/Singapore",
  "dependencyDashboard": true,
  "labels": [
    "dependencies",
    "renovate"
  ],
  "enabledManagers": [
    "flux",
    "github-actions",
    "helm-values"
  ],
  "ignorePaths": [
    "flux/flux-system/**",
    "apps/blog/**",
    "apps/mmcal/**",
    "apps/rangoon-mapper/**",
    "apps/ericaknight/**"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 5,
  "flux": {
    "managerFilePatterns": [
      "/(^|/)(apps|core|infrastructure)/.+\\.ya?ml$/",
      "/(^|/)flux/repositories/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)(apps|core|infrastructure)/.+(helmrelease|values)\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Keep the intentionally pinned Flaresolverr fork manual.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "alexfozor/flaresolverr"
      ],
      "enabled": false
    },
    {
      "description": "Keep private Multica app images manual; GHCR package lookup is not available to Renovate.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/khzaw/multica-web",
        "ghcr.io/khzaw/multica-backend"
      ],
      "enabled": false
    },
    {
      "description": "Track Jackett's three-part app versions with optional ls build tags.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "lscr.io/linuxserver/jackett"
      ],
      "versioning": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?:-ls(?<build>\\d+))?$"
    },
    {
      "description": "Track LinuxServer images with four-part app versions and moving ls build tags.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "lscr.io/linuxserver/prowlarr",
        "lscr.io/linuxserver/radarr",
        "lscr.io/linuxserver/sonarr"
      ],
      "versioning": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)(?:-ls(?<revision>\\d+))?$"
    },
    {
      "description": "Track LinuxServer images with three-part app versions and moving ls build tags.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "lscr.io/linuxserver/bazarr",
        "lscr.io/linuxserver/calibre",
        "lscr.io/linuxserver/sabnzbd",
        "lscr.io/linuxserver/speedtest-tracker"
      ],
      "versioning": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-ls(?<build>\\d+)$"
    },
    {
      "description": "Track LinuxServer Jellyfin while preserving the Ubuntu base compatibility suffix.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "lscr.io/linuxserver/jellyfin"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?<compatibility>ubu\\d+)-ls(?<build>\\d+)$"
    },
    {
      "description": "Track LinuxServer images with r and ls build components.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "lscr.io/linuxserver/mariadb",
        "lscr.io/linuxserver/transmission"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-r(?<build>\\d+)-ls(?<revision>\\d+)$"
    },
    {
      "description": "Keep AdGuard primary image updates in their own branch and PR.",
      "matchManagers": [
        "helm-values"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "adguard/adguardhome"
      ],
      "matchFileNames": [
        "apps/adguard/primary/helmrelease.yaml"
      ],
      "additionalBranchPrefix": "adguard-primary-",
      "commitMessageSuffix": " (adguard primary)"
    },
    {
      "description": "Keep AdGuard secondary image updates in their own branch and PR.",
      "matchManagers": [
        "helm-values"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "adguard/adguardhome"
      ],
      "matchFileNames": [
        "apps/adguard/secondary/helmrelease.yaml"
      ],
      "additionalBranchPrefix": "adguard-secondary-",
      "commitMessageSuffix": " (adguard secondary)"
    },
    {
      "description": "Prioritize Subarr image updates so the app does not sit behind the general media backlog.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/coaxk/subarr"
      ],
      "prPriority": 20
    },
    {
      "description": "Group GitHub Actions patch and minor updates.",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "github actions patch and minor updates"
    }
  ]
}
