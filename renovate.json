{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Asia/Singapore",
  "dependencyDashboard": true,
  "labels": [
    "dependencies",
    "renovate"
  ],
  "enabledManagers": [
    "flux",
    "github-actions",
    "helm-values"
  ],
  "ignorePaths": [
    "flux/flux-system/**",
    "apps/blog/**",
    "apps/mmcal/**",
    "apps/rangoon-mapper/**"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "flux": {
    "managerFilePatterns": [
      "/(^|/)(apps|core|infrastructure)/.+\\.ya?ml$/",
      "/(^|/)flux/repositories/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)(apps|core|infrastructure)/.+(helmrelease|values)\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Keep the intentionally pinned Flaresolverr fork manual.",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "alexfozor/flaresolverr"
      ],
      "enabled": false
    },
    {
      "description": "Keep AdGuard primary image updates in their own branch and PR.",
      "matchManagers": [
        "helm-values"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "adguard/adguardhome"
      ],
      "matchFileNames": [
        "apps/adguard/primary/helmrelease.yaml"
      ],
      "additionalBranchPrefix": "adguard-primary-",
      "commitMessageSuffix": " (adguard primary)"
    },
    {
      "description": "Keep AdGuard secondary image updates in their own branch and PR.",
      "matchManagers": [
        "helm-values"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "adguard/adguardhome"
      ],
      "matchFileNames": [
        "apps/adguard/secondary/helmrelease.yaml"
      ],
      "additionalBranchPrefix": "adguard-secondary-",
      "commitMessageSuffix": " (adguard secondary)"
    },
    {
      "description": "Group Helm chart patch and minor updates.",
      "matchManagers": [
        "flux"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "helm chart patch and minor updates"
    },
    {
      "description": "Group GitHub Actions patch and minor updates.",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "github actions patch and minor updates"
    }
  ]
}
